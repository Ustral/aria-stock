# Copy to .env for local dev. In production set these in your host's dashboard.

# JWT signing secret — anyone with this can forge sessions. Keep it private.
# Required when NODE_ENV=production (the server refuses to start without it).
JWT_SECRET=change-me-to-a-long-random-string

# Local API port (kept separate from the web dev server's PORT).
API_PORT=8787

# Database. LEAVE UNSET locally to use the zero-config JSON-file store.
# Set it in production to use Postgres (e.g. Neon / Supabase):
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Set by the host in production; do not set locally.
# NODE_ENV=production
